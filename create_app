#!/bin/bash

# ─── ANSI Colors ──────────────────────────────────────────────
R='\033[0;31m'    # Red
G='\033[0;32m'    # Green
B='\033[0;34m'    # Blue
C='\033[0;36m'    # Cyan
M='\033[0;35m'    # Magenta
Y='\033[1;33m'    # Yellow
W='\033[1;37m'    # White bold
DIM='\033[2m'     # Dim
BOLD='\033[1m'    # Bold
NC='\033[0m'      # No Color
CHECK="${G}✓${NC}"
CROSS="${R}✗${NC}"
ARROW="${C}→${NC}"

# ─── Banner ───────────────────────────────────────────────────
clear
echo ""
echo -e "${B}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${B}║${NC}  ${M}${BOLD}  GetX Starter CLI${NC}  ${DIM}v1.0.0${NC}                      ${B}║${NC}"
echo -e "${B}║${NC}  ${DIM}Flutter boilerplate generator with GetX${NC}         ${B}║${NC}"
echo -e "${B}╚══════════════════════════════════════════════════╝${NC}"
echo ""

# ─── Step 1: Project Name ─────────────────────────────────────
echo -e "${Y}${BOLD}STEP 1: Project Name${NC}"
echo -e "${DIM}Must be lowercase, use underscores, start with a letter${NC}"
echo -e "${DIM}Example: my_awesome_app${NC}"
echo ""

while true; do
  echo -ne "${C}${BOLD}  Project name: ${NC}"
  read PROJECT_NAME

  if [ -z "$PROJECT_NAME" ]; then
    echo -e "  ${CROSS} ${R}Project name cannot be empty${NC}"
    continue
  fi

  if [[ ! "$PROJECT_NAME" =~ ^[a-z][a-z0-9_]*$ ]]; then
    echo -e "  ${CROSS} ${R}Invalid name!${NC} Must be ${W}lowercase${NC}, use ${W}underscores${NC}, start with a ${W}letter${NC}"
    echo -e "    ${DIM}No spaces, hyphens, uppercase, or special characters${NC}"
    continue
  fi

  if [[ ${#PROJECT_NAME} -lt 2 ]]; then
    echo -e "  ${CROSS} ${R}Name must be at least 2 characters${NC}"
    continue
  fi

  if [[ "$PROJECT_NAME" =~ ^(test|flutter|dart|android|ios|web|linux|macos|windows)$ ]]; then
    echo -e "  ${CROSS} ${R}'${PROJECT_NAME}' is a reserved name${NC}"
    continue
  fi

  echo -e "  ${CHECK} ${G}Project name: ${W}${PROJECT_NAME}${NC}"
  break
done

echo ""

# ─── Step 2: App Display Name ─────────────────────────────────
echo -e "${Y}${BOLD}STEP 2: App Display Name${NC}"
echo -e "${DIM}The name shown under the app icon (e.g. My App)${NC}"
echo ""

echo -ne "${C}${BOLD}  Display name: ${NC}"
read APP_DISPLAY_NAME

if [ -z "$APP_DISPLAY_NAME" ]; then
  APP_DISPLAY_NAME="$PROJECT_NAME"
fi
echo -e "  ${CHECK} ${G}Display name: ${W}${APP_DISPLAY_NAME}${NC}"

echo ""

# ─── Step 3: Organization ─────────────────────────────────────
echo -e "${Y}${BOLD}STEP 3: Organization (Bundle ID prefix)${NC}"
echo -e "${DIM}Reverse domain format, e.g. com.example${NC}"
echo ""

while true; do
  echo -ne "${C}${BOLD}  Organization: ${NC}"
  read ORG_NAME

  if [ -z "$ORG_NAME" ]; then
    echo -e "  ${CROSS} ${R}Organization cannot be empty${NC}"
    continue
  fi

  if [[ ! "$ORG_NAME" =~ ^[a-z][a-z0-9]*(\.[a-z][a-z0-9]*)+$ ]]; then
    echo -e "  ${CROSS} ${R}Invalid format!${NC} Use reverse domain like ${W}com.company${NC}"
    continue
  fi

  echo -e "  ${CHECK} ${G}Organization: ${W}${ORG_NAME}${NC}"
  echo -e "  ${DIM}Bundle ID will be: ${ORG_NAME}.${PROJECT_NAME}${NC}"
  break
done

echo ""

# ─── Step 4: Platforms ────────────────────────────────────────
echo -e "${Y}${BOLD}STEP 4: Target Platforms${NC}"
echo -e "${DIM}Select platforms (comma-separated numbers)${NC}"
echo ""
echo -e "  ${W}1${NC}) ${G}Android${NC}"
echo -e "  ${W}2${NC}) ${G}iOS${NC}"
echo -e "  ${W}3${NC}) ${B}Web${NC}"
echo -e "  ${W}4${NC}) ${M}macOS${NC}"
echo -e "  ${W}5${NC}) ${C}Windows${NC}"
echo -e "  ${W}6${NC}) ${Y}Linux${NC}"
echo ""

while true; do
  echo -ne "${C}${BOLD}  Choose platforms (e.g. 1,2 or 1,2,3): ${NC}"
  read PLATFORM_INPUT

  if [ -z "$PLATFORM_INPUT" ]; then
    echo -e "  ${CROSS} ${R}Please select at least one platform${NC}"
    continue
  fi

  PLATFORMS=""
  PLATFORM_DISPLAY=""
  VALID=true

  IFS=',' read -ra NUMS <<< "$PLATFORM_INPUT"
  for num in "${NUMS[@]}"; do
    num=$(echo "$num" | tr -d ' ')
    case $num in
      1) PLATFORMS+="android,"; PLATFORM_DISPLAY+="${G}Android${NC} ";;
      2) PLATFORMS+="ios,"; PLATFORM_DISPLAY+="${G}iOS${NC} ";;
      3) PLATFORMS+="web,"; PLATFORM_DISPLAY+="${B}Web${NC} ";;
      4) PLATFORMS+="macos,"; PLATFORM_DISPLAY+="${M}macOS${NC} ";;
      5) PLATFORMS+="windows,"; PLATFORM_DISPLAY+="${C}Windows${NC} ";;
      6) PLATFORMS+="linux,"; PLATFORM_DISPLAY+="${Y}Linux${NC} ";;
      *) echo -e "  ${CROSS} ${R}Invalid option: ${num}${NC}"; VALID=false; break;;
    esac
  done

  if [ "$VALID" = false ]; then
    continue
  fi

  PLATFORMS=${PLATFORMS%,}
  echo -e "  ${CHECK} Platforms: ${PLATFORM_DISPLAY}"
  break
done

echo ""

# ─── Confirmation ─────────────────────────────────────────────
echo -e "${B}══════════════════════════════════════════════════${NC}"
echo -e "  ${W}${BOLD}Summary${NC}"
echo -e "  ${ARROW} Project:      ${W}${PROJECT_NAME}${NC}"
echo -e "  ${ARROW} Display Name: ${W}${APP_DISPLAY_NAME}${NC}"
echo -e "  ${ARROW} Bundle ID:    ${W}${ORG_NAME}.${PROJECT_NAME}${NC}"
echo -e "  ${ARROW} Platforms:    ${PLATFORM_DISPLAY}"
echo -e "${B}══════════════════════════════════════════════════${NC}"
echo ""
echo -ne "${Y}${BOLD}  Proceed? (Y/n): ${NC}"
read CONFIRM

if [[ "$CONFIRM" =~ ^[nN] ]]; then
  echo -e "\n  ${CROSS} ${R}Cancelled.${NC}\n"
  exit 0
fi

echo ""

# ─── Step 5: Create Flutter Project ──────────────────────────
echo -e "${M}${BOLD}Creating Flutter project...${NC}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
OUTPUT_DIR="$(pwd)"

if [ -d "$PROJECT_NAME" ]; then
  echo -e "  ${Y}Directory '${PROJECT_NAME}' already exists.${NC}"
  echo -ne "  ${C}${BOLD}Overwrite? (y/N): ${NC}"
  read OVERWRITE
  if [[ "$OVERWRITE" =~ ^[yY] ]]; then
    rm -rf "$PROJECT_NAME"
    echo -e "  ${CHECK} ${G}Removed existing directory${NC}"
  else
    echo -e "\n  ${CROSS} ${R}Cancelled. Remove the directory manually or choose a different name.${NC}\n"
    exit 1
  fi
fi

FLUTTER_OUTPUT=$(flutter create "$PROJECT_NAME" \
  --org "$ORG_NAME" \
  --platforms "$PLATFORMS" \
  --no-pub 2>&1)
FLUTTER_EXIT=$?

if [ $FLUTTER_EXIT -ne 0 ] || [ ! -d "$PROJECT_NAME" ]; then
  echo -e "  ${CROSS} ${R}Failed to create Flutter project${NC}"
  echo -e "  ${DIM}${FLUTTER_OUTPUT}${NC}"
  exit 1
fi

echo -e "  ${CHECK} ${G}Flutter project created${NC}"

PROJECT_DIR="${OUTPUT_DIR}/${PROJECT_NAME}"

# ─── Step 6: Create Directory Structure ──────────────────────
echo -e "${M}${BOLD}Setting up project structure...${NC}"

mkdir -p "$PROJECT_DIR/lib/core/bindings"
mkdir -p "$PROJECT_DIR/lib/core/common/styles"
mkdir -p "$PROJECT_DIR/lib/core/common/widgets"
mkdir -p "$PROJECT_DIR/lib/core/controller"
mkdir -p "$PROJECT_DIR/lib/core/models"
mkdir -p "$PROJECT_DIR/lib/core/services"
mkdir -p "$PROJECT_DIR/lib/core/utils/constants"
mkdir -p "$PROJECT_DIR/lib/core/utils/helpers"
mkdir -p "$PROJECT_DIR/lib/core/utils/theme/custom_themes"
mkdir -p "$PROJECT_DIR/lib/features/home/controller"
mkdir -p "$PROJECT_DIR/lib/features/home/views/screens"
mkdir -p "$PROJECT_DIR/lib/routes"

echo -e "  ${CHECK} ${G}Directory structure created${NC}"

# ─── Step 7: Write Core Files ────────────────────────────────
echo -e "${M}${BOLD}Generating core files...${NC}"

PKG="$PROJECT_NAME"

# --- .env ---
cat > "$PROJECT_DIR/.env" << 'ENVEOF'
BASE_URL=https://your-api.example.com
ENVEOF

